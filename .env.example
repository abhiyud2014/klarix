# Groq API Key (required for LLM functionality)
# Get your key from: https://console.groq.com/
# IMPORTANT: Add your actual key to a .env file (not committed to git)
VITE_GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL Database (optional - uses AlaSQL in-browser if not set)
# Get free database from: https://neon.tech
DATABASE_URL=postgresql://user:password@host/database
VITE_USE_POSTGRES=false
